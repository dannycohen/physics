---
interface Props {
  slug: string;
  limits: Array<{
    label: string;
    icon?: string;
    collapse: string;
    values: Record<string, number>;
  }>;
}

const { slug, limits } = Astro.props;
---

<limit-snaps data-slug={slug}>
  <div class="limit-group" role="group" aria-label="Limiting cases">
    {
      limits.map((limit) => (
        <button
          type="button"
          class="chip"
          data-values={JSON.stringify(limit.values)}
          data-collapse={limit.collapse}
        >
          {limit.icon && <span aria-hidden="true">{limit.icon} </span>}
          {limit.label}
        </button>
      ))
    }
  </div>
  <p class="limit-collapse" aria-live="polite"></p>
</limit-snaps>

<script>
  import { getVizStore } from '../lib/vizStore';

  class LimitSnapsElement extends HTMLElement {
    #bound = false;

    connectedCallback() {
      if (this.#bound) return;
      this.#bound = true;

      const store = getVizStore(this.dataset.slug ?? '');
      const collapse = this.querySelector('.limit-collapse');
      // The values the visible text describes; cleared once the store diverges.
      let active: Record<string, number> | null = null;

      for (const button of this.querySelectorAll<HTMLButtonElement>('button[data-values]')) {
        button.addEventListener('click', () => {
          const values = JSON.parse(button.dataset.values ?? '{}') as Record<string, number>;
          for (const [key, value] of Object.entries(values)) {
            store.set(key, value);
          }
          active = values;
          if (collapse) collapse.textContent = button.dataset.collapse ?? '';
        });
      }

      store.values.subscribe((values) => {
        if (!active || !collapse) return;
        if (Object.entries(active).some(([key, value]) => values[key] !== value)) {
          active = null;
          collapse.textContent = '';
        }
      });
    }
  }

  if (!customElements.get('limit-snaps')) {
    customElements.define('limit-snaps', LimitSnapsElement);
  }
</script>

<style>
  .limit-group {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .limit-collapse {
    min-height: 3.2em; /* two lines: collapse text is kept short enough to fit */
    margin-block: var(--space-2) 0;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.9rem;
  }
</style>
