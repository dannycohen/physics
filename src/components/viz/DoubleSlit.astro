---
import { highestOrder, maximaAngleDeg } from '../../lib/physics/doubleslit';
import { formatQuantity } from '../../lib/format';

// Build-time snapshot for the no-JS / screen-reader table and default readout.
const DEFAULT_WAVELENGTH = 550; // nm (green)
const DEFAULT_SPACING = 2500; // nm

const angleText = (deg: number) => formatQuantity(deg, '°', { sigFigs: 3 });

const defaultN = highestOrder(DEFAULT_WAVELENGTH, DEFAULT_SPACING);
const defaultTheta1 = maximaAngleDeg(1, DEFAULT_WAVELENGTH, DEFAULT_SPACING);

// Orders 0..6 so the table shows where the pattern runs out of room.
const TABLE_ORDERS = [0, 1, 2, 3, 4, 5, 6];
const rows = TABLE_ORDERS.map((m) => {
  const angle = maximaAngleDeg(m, DEFAULT_WAVELENGTH, DEFAULT_SPACING);
  return {
    order: String(m),
    angle: angle === null ? 'does not exist' : angleText(angle),
  };
});
---

<double-slit>
  <figure class="slit-figure">
    <div class="canvas-box">
      <canvas
        role="img"
        aria-label="A schematic of the double-slit experiment. Light passes through two narrow slits in a barrier on the left and spreads out to a screen on the right, where it forms a row of evenly spaced bright fringes coloured by the light's wavelength. A central bright fringe sits straight ahead, with matching orders above and below. Longer wavelengths or closer slits spread the fringes wider; only a finite number of orders fit on each side."
      ></canvas>
    </div>
    <p class="slit-stat" aria-hidden="true">
      First-order angle <b class="theta-val">{
        defaultTheta1 === null ? 'none' : angleText(defaultTheta1)
      }</b>, <b class="orders-val">{defaultN}</b> bright orders each side
    </p>
    <span class="visually-hidden" aria-live="polite">
      {
        defaultTheta1 === null
          ? `Only the central fringe fits; no off-centre orders exist at this wavelength and slit spacing.`
          : `The first bright fringe sits ${angleText(defaultTheta1)} from centre, with ${defaultN} bright orders on each side.`
      }
    </span>
  </figure>
  <details class="view-table">
    <summary>View as table</summary>
    <p>
      Angle to each bright fringe for {DEFAULT_WAVELENGTH} nm light through slits {DEFAULT_SPACING} nm
      apart. The centre fringe is at 0°; higher orders spread wider until m·λ exceeds d and the order
      no longer fits.
    </p>
    <table>
      <thead>
        <tr>
          <th scope="col">Order m</th>
          <th scope="col">Angle to fringe</th>
        </tr>
      </thead>
      <tbody>
        {
          rows.map((row) => (
            <tr>
              <td>{row.order}</td>
              <td>{row.angle}</td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </details>
</double-slit>

<script>
  import { createVizCanvas } from '../../lib/canvas';
  import { highestOrder, maximaAngleDeg } from '../../lib/physics/doubleslit';
  import { formatQuantity } from '../../lib/format';
  import { getVizStore } from '../../lib/vizStore';

  const SLUG = 'waves-optics/double-slit';
  const DEFAULT_WAVELENGTH = 550;
  const DEFAULT_SPACING = 2500;

  // This island seeds the shared store; it precedes the controls in the MDX and
  // module scripts run in document order, so it seeds before they connect.
  const store = getVizStore(SLUG, {
    wavelength: DEFAULT_WAVELENGTH,
    spacing: DEFAULT_SPACING,
  });

  const num = (values: Record<string, number>, key: string, fallback: number) =>
    values[key] ?? fallback;
  const angleText = (deg: number) => formatQuantity(deg, '°', { sigFigs: 3 });

  // Approximate visible-spectrum colour for a wavelength in nm (the slider stays
  // inside the visible band, so this always returns a colour).
  function visibleColor(wl: number): string {
    let r = 0;
    let g = 0;
    let b = 0;
    if (wl < 440) {
      r = -(wl - 440) / (440 - 380);
      b = 1;
    } else if (wl < 490) {
      g = (wl - 440) / (490 - 440);
      b = 1;
    } else if (wl < 510) {
      g = 1;
      b = -(wl - 510) / (510 - 490);
    } else if (wl < 580) {
      r = (wl - 510) / (580 - 510);
      g = 1;
    } else if (wl < 645) {
      r = 1;
      g = -(wl - 645) / (645 - 580);
    } else {
      r = 1;
    }
    let factor = 1;
    if (wl < 420) factor = 0.3 + (0.7 * (wl - 380)) / (420 - 380);
    else if (wl > 700) factor = 0.3 + (0.7 * (750 - wl)) / (750 - 700);
    const ch = (c: number) => Math.round(255 * Math.pow(Math.max(0, c) * factor, 0.8));
    return `rgb(${ch(r)}, ${ch(g)}, ${ch(b)})`;
  }

  // Fringe screen position ∝ tan θ, on a fixed scale so the pattern visibly
  // spreads (larger λ / smaller d) or bunches (smaller λ / larger d). Clamped to
  // the screen so a near-90° highest order stays drawn at the edge rather than
  // running off to infinity. tan is only ever evaluated for orders that exist.
  const TAN_REF = Math.tan((30 * Math.PI) / 180); // 30° fringe sits at 40% of the half-height

  class DoubleSlitElement extends HTMLElement {
    #bound = false;

    connectedCallback() {
      if (this.#bound) return;
      this.#bound = true;

      const canvas = this.querySelector('canvas');
      if (!canvas) return;

      const thetaVal = this.querySelector('.theta-val');
      const ordersVal = this.querySelector('.orders-val');
      const live = this.querySelector('.visually-hidden');

      const handle = createVizCanvas(canvas, (ctx, size, theme) => {
        const v = store.values.get();
        const wl = num(v, 'wavelength', DEFAULT_WAVELENGTH);
        const d = num(v, 'spacing', DEFAULT_SPACING);
        const color = visibleColor(wl);
        const N = highestOrder(wl, d);

        ctx.fillStyle = theme.bg;
        ctx.fillRect(0, 0, size.w, size.h);

        const barrierX = size.w * 0.2;
        const screenX = size.w * 0.9;
        const cy = size.h * 0.5;
        const halfH = size.h * 0.45;
        const yScale = (0.4 * halfH) / TAN_REF; // pixels per unit tan θ

        // Slit separation: a subtle schematic cue that grows with d.
        const slitGap = Math.min(size.h * 0.28, size.h * 0.1 + (d / 5000) * size.h * 0.18);
        const slitY1 = cy - slitGap / 2;
        const slitY2 = cy + slitGap / 2;
        const slitHalf = Math.max(4, size.h * 0.02);

        // Incoming plane wavefronts on the left, tinted by the light's colour.
        ctx.save();
        ctx.strokeStyle = color;
        ctx.globalAlpha = 0.35;
        ctx.lineWidth = 2;
        for (let i = 0; i < 4; i++) {
          const x = size.w * 0.03 + i * (barrierX - size.w * 0.03 - 6) * 0.28;
          ctx.beginPath();
          ctx.moveTo(x, cy - halfH);
          ctx.lineTo(x, cy + halfH);
          ctx.stroke();
        }
        ctx.restore();

        // Fringe screen positions: order 0..N, mirrored above and below centre.
        const fringeY = (m: number): number => {
          const angle = maximaAngleDeg(m, wl, d); // never null for m <= N
          if (angle === null) return cy;
          const t = Math.tan((angle * Math.PI) / 180);
          const offset = Math.min(t * yScale, halfH);
          return offset;
        };

        // Faint rays from the slit midpoint out to each bright fringe.
        ctx.save();
        ctx.strokeStyle = color;
        ctx.globalAlpha = 0.22;
        ctx.lineWidth = 1.5;
        for (let m = 0; m <= N; m++) {
          const off = fringeY(m);
          for (const s of m === 0 ? [0] : [-1, 1]) {
            ctx.beginPath();
            ctx.moveTo(barrierX, cy);
            ctx.lineTo(screenX, cy + s * off);
            ctx.stroke();
          }
        }
        ctx.restore();

        // The barrier: an opaque wall with two gaps (the slits).
        ctx.fillStyle = theme.axis;
        ctx.fillRect(barrierX - 4, cy - halfH, 8, halfH - slitGap / 2 - slitHalf);
        ctx.fillRect(barrierX - 4, slitY1 + slitHalf, 8, slitGap - 2 * slitHalf);
        ctx.fillRect(barrierX - 4, slitY2 + slitHalf, 8, halfH - slitGap / 2 - slitHalf);

        // The screen (a thin vertical bar on the right).
        ctx.fillStyle = theme.grid;
        ctx.fillRect(screenX, cy - halfH, 3, 2 * halfH);

        // Bright fringes on the screen, coloured by wavelength. All two-slit
        // maxima are equally bright; a soft glow sells the "bright band" idea.
        for (let m = 0; m <= N; m++) {
          const off = fringeY(m);
          for (const s of m === 0 ? [0] : [-1, 1]) {
            const y = cy + s * off;
            ctx.save();
            ctx.fillStyle = color;
            ctx.shadowColor = color;
            ctx.shadowBlur = 12;
            ctx.beginPath();
            ctx.ellipse(screenX + 1.5, y, 5, 7, 0, 0, Math.PI * 2);
            ctx.fill();
            ctx.restore();
          }
        }

        // Label the central maximum and the highest order that fits.
        ctx.fillStyle = theme.label;
        ctx.font = '12px system-ui, sans-serif';
        ctx.textAlign = 'right';
        ctx.textBaseline = 'middle';
        ctx.fillText('m = 0', screenX - 10, cy);
        if (N >= 1) {
          const topY = cy - fringeY(N);
          ctx.textBaseline = 'bottom';
          ctx.fillText(`m = ${N}`, screenX - 10, topY - 4);
        }

        // Slit labels.
        ctx.fillStyle = theme.label;
        ctx.font = '11px system-ui, sans-serif';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'top';
        ctx.fillText('slits', barrierX, cy + halfH + 4);
        ctx.fillText('screen', screenX, cy + halfH + 4);
      });

      const renderStat = (values: Record<string, number>) => {
        const wl = num(values, 'wavelength', DEFAULT_WAVELENGTH);
        const d = num(values, 'spacing', DEFAULT_SPACING);
        const theta1 = maximaAngleDeg(1, wl, d);
        const N = highestOrder(wl, d);
        if (thetaVal) thetaVal.textContent = theta1 === null ? 'none' : angleText(theta1);
        if (ordersVal) ordersVal.textContent = String(N);
      };

      store.values.subscribe((values) => {
        renderStat(values);
        handle.redraw();
      });

      store.onSettled((values) => {
        const wl = num(values, 'wavelength', DEFAULT_WAVELENGTH);
        const d = num(values, 'spacing', DEFAULT_SPACING);
        const theta1 = maximaAngleDeg(1, wl, d);
        const N = highestOrder(wl, d);
        const text =
          theta1 === null
            ? `Only the central fringe fits; no off-centre orders exist at this wavelength and slit spacing.`
            : `The first bright fringe sits ${angleText(theta1)} from centre, with ${N} bright orders on each side.`;
        if (live && live.textContent?.trim() !== text) live.textContent = text;
      });
    }
  }

  if (!customElements.get('double-slit')) {
    customElements.define('double-slit', DoubleSlitElement);
  }
</script>

<style>
  .slit-figure {
    margin: 0;
  }

  .canvas-box {
    aspect-ratio: 16 / 10;
  }

  .slit-stat {
    margin-block: var(--space-2) 0;
    font-size: 1.05rem;
  }

  .slit-stat b {
    font-variant-numeric: tabular-nums;
    color: var(--viz-curve);
  }
</style>
