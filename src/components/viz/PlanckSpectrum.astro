---
import { peakWavelength, spectralRadiance } from '../../lib/physics/planck';
import { formatQuantity } from '../../lib/format';

// Build-time snapshot for the no-JS / screen-reader table and the default stat.
const DEFAULT_TEMP = 5778; // the Sun's photosphere

const nm = (v: number) => formatQuantity(v, 'nm', { sigFigs: 3 });
const band = (nmValue: number): string =>
  nmValue < 380 ? 'ultraviolet' : nmValue > 750 ? 'infrared' : 'visible';

const sunPeakNm = peakWavelength(DEFAULT_TEMP) * 1e9;
// Table normalised to the Sun's own peak radiance (so the peak row reads 1).
const sunPeakRadiance = spectralRadiance(peakWavelength(DEFAULT_TEMP), DEFAULT_TEMP);
const SAMPLE_NM = [100, 200, 300, 380, 502, 600, 750, 1000, 1500, 2000];
const rows = SAMPLE_NM.map((wl) => ({
  wavelength: formatQuantity(wl, ''),
  relative: formatQuantity(
    spectralRadiance(wl * 1e-9, DEFAULT_TEMP) / sunPeakRadiance,
    '',
    { sigFigs: 2 },
  ),
}));
---

<planck-spectrum>
  <figure class="dist-figure">
    <div class="canvas-box">
      <canvas
        role="img"
        aria-label="Graph of how brightly a hot object glows at each wavelength of light. The curve rises from zero, peaks at one wavelength, then falls away in a long tail. A faint band marks the visible-light range. Raising the temperature slides the peak toward shorter, bluer wavelengths; each curve is scaled to its own peak so its shape stays visible at any temperature."
      ></canvas>
    </div>
    <p class="peak-stat" aria-hidden="true">
      <span class="stat"><span class="swatch swatch-curve"></span>glow curve</span>
      <span class="stat"><span class="swatch swatch-peak"></span>peak at <b class="peak-val">{nm(sunPeakNm)}</b> ({band(sunPeakNm)})</span>
      <span class="stat"><span class="swatch swatch-visible"></span>visible band 380–750 nm</span>
    </p>
    <span class="visually-hidden" aria-live="polite">
      At {DEFAULT_TEMP} K the glow peaks at {nm(sunPeakNm)}, in the {band(sunPeakNm)} range.
    </span>
  </figure>
  <details class="view-table">
    <summary>View as table</summary>
    <p>
      For the Sun at {DEFAULT_TEMP} K the glow rises from near zero in the ultraviolet, peaks
      around {nm(sunPeakNm)} in the visible band, then tails off into the infrared. Brightness is
      relative to the peak.
    </p>
    <table>
      <thead>
        <tr>
          <th scope="col">Wavelength (nm)</th>
          <th scope="col">Relative brightness (peak = 1)</th>
        </tr>
      </thead>
      <tbody>
        {
          rows.map((row) => (
            <tr>
              <td>{row.wavelength}</td>
              <td>{row.relative}</td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </details>
</planck-spectrum>

<script>
  import { createVizCanvas } from '../../lib/canvas';
  import { plotCurve, type Series } from '../../lib/plotCurve';
  import { peakWavelength, spectralRadiance } from '../../lib/physics/planck';
  import { formatQuantity } from '../../lib/format';
  import { getVizStore } from '../../lib/vizStore';

  const SLUG = 'thermodynamics/planck-blackbody';
  const DEFAULT_TEMP = 5778;
  const NM_MIN = 50;
  const NM_MAX = 3000; // wide enough that even the ~1000 K peak (~2900 nm) stays on-screen
  const STEPS = 240;

  // This island seeds the shared store so it exists before the controls connect;
  // the MDX places <PlanckSpectrum /> ahead of the controls, and module scripts
  // run in document order.
  const store = getVizStore(SLUG, { tempK: DEFAULT_TEMP });

  const nm = (v: number) => formatQuantity(v, 'nm', { sigFigs: 3 });
  const band = (nmValue: number): string =>
    nmValue < 380 ? 'ultraviolet' : nmValue > 750 ? 'infrared' : 'visible';
  const readTemp = (values: Record<string, number>) => values['tempK'] ?? DEFAULT_TEMP;

  class PlanckSpectrumElement extends HTMLElement {
    #bound = false;

    connectedCallback() {
      if (this.#bound) return;
      this.#bound = true;

      const canvas = this.querySelector('canvas');
      if (!canvas) return;

      const peakVal = this.querySelector('.peak-val');
      const live = this.querySelector('.visually-hidden');

      const handle = createVizCanvas(canvas, (ctx, size, theme) => {
        const tempK = readTemp(store.values.get());
        // Normalise to THIS temperature's own peak so every curve fills the plot;
        // blackbody brightness spans many orders of magnitude across this range,
        // so a single fixed scale would hide every cool curve.
        const normRef = spectralRadiance(peakWavelength(tempK), tempK);

        const curve: Array<[number, number]> = [];
        for (let i = 0; i <= STEPS; i++) {
          const wl = NM_MIN + (i / STEPS) * (NM_MAX - NM_MIN);
          curve.push([wl, spectralRadiance(wl * 1e-9, tempK) / normRef]);
        }

        const peakNm = peakWavelength(tempK) * 1e9;

        // Vertical helper lines from the x-axis to the top of the plot.
        const vertical = (x: number, color: string, label: string, dash: number[]): Series => ({
          points: [
            [x, 0],
            [x, 1.05],
          ],
          color,
          label,
          dash,
        });

        // Faint grid-coloured edges mark the visible band (380–750 nm); the right
        // edge carries the text label so colour is never the only cue.
        const series: Series[] = [
          vertical(380, theme.grid, '', [4, 4]),
          vertical(750, theme.grid, 'visible', [4, 4]),
          vertical(peakNm, theme.active, 'peak', [2, 3]),
          { points: curve, color: theme.curve, label: '' },
        ];

        plotCurve(ctx, size, theme, {
          series,
          xLabel: 'wavelength (nm)',
          yLabel: 'relative brightness',
          xDomain: [NM_MIN, NM_MAX],
          yDomain: [0, 1.05],
        });
      });

      const renderStat = (values: Record<string, number>) => {
        const peakNm = peakWavelength(readTemp(values)) * 1e9;
        if (peakVal) peakVal.textContent = `${nm(peakNm)} (${band(peakNm)})`;
      };

      store.values.subscribe((values) => {
        renderStat(values);
        handle.redraw();
      });

      // Screen-reader summary once the value settles, so a drag does not flood.
      store.onSettled((values) => {
        const t = readTemp(values);
        const peakNm = peakWavelength(t) * 1e9;
        const text = `At ${formatQuantity(t, 'K', { sigFigs: 4 })} the glow peaks at ${nm(peakNm)}, in the ${band(peakNm)} range.`;
        if (live && live.textContent?.trim() !== text) live.textContent = text;
      });
    }
  }

  if (!customElements.get('planck-spectrum')) {
    customElements.define('planck-spectrum', PlanckSpectrumElement);
  }
</script>

<style>
  .dist-figure {
    margin: 0;
  }

  .canvas-box {
    aspect-ratio: 16 / 10;
  }

  .peak-stat {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-4);
    margin-block: var(--space-2) 0;
    font-size: 0.95rem;
  }

  .stat {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
  }

  .stat b {
    font-variant-numeric: tabular-nums;
  }

  /* Swatches echo each line's dash pattern so colour is never the only cue. */
  .swatch {
    display: inline-block;
    width: 20px;
    height: 0;
    border-top-width: 3px;
  }

  .swatch-curve {
    border-top: 3px solid var(--viz-curve);
  }

  .swatch-peak {
    border-top: 3px dotted var(--viz-active);
  }

  .swatch-visible {
    border-top: 3px dashed var(--viz-grid);
  }
</style>
