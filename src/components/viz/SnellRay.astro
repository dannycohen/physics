---
import { criticalAngleDeg, refractionAngleDeg } from '../../lib/physics/snell';
import { formatQuantity } from '../../lib/format';

// Build-time snapshot for the no-JS / screen-reader table and default readout.
const DEFAULT_N1 = 1;
const DEFAULT_N2 = 1.5;
const DEFAULT_INCIDENT = 40;

const angleText = (deg: number) => formatQuantity(deg, '°', { sigFigs: 3 });

const defaultRefracted = refractionAngleDeg(DEFAULT_N1, DEFAULT_N2, DEFAULT_INCIDENT);
const defaultRefractedText =
  defaultRefracted === null ? 'total internal reflection' : angleText(defaultRefracted);

// View-as-table: incident vs refracted for the default indices, flagging where
// total internal reflection sets in (only possible when n1 > n2).
const defaultCritical = criticalAngleDeg(DEFAULT_N1, DEFAULT_N2);
const SAMPLE_INCIDENT = [0, 10, 20, 30, 40, 50, 60, 70, 80];
const rows = SAMPLE_INCIDENT.map((deg) => {
  const refracted = refractionAngleDeg(DEFAULT_N1, DEFAULT_N2, deg);
  return {
    incident: angleText(deg),
    refracted: refracted === null ? 'total internal reflection' : angleText(refracted),
  };
});
---

<snell-ray>
  <figure class="field-figure">
    <div class="canvas-box">
      <canvas
        role="img"
        aria-label="A light ray strikes a horizontal boundary between two materials, drawn with a dashed normal line. Below the boundary the ray bends toward the normal when entering a denser material and away when entering a lighter one. When the ray goes from a denser to a lighter material past the critical angle it cannot escape and reflects entirely back, labelled total internal reflection."
      ></canvas>
    </div>
    <p class="ray-stat" aria-hidden="true">
      Incident <b class="incident-val">{angleText(DEFAULT_INCIDENT)}</b>
      → refracted <b class="refracted-val">{defaultRefractedText}</b>
    </p>
    <span class="visually-hidden" aria-live="polite">
      An incident angle of {angleText(DEFAULT_INCIDENT)} gives a refracted angle of {
        defaultRefractedText
      }.
    </span>
  </figure>
  <details class="view-table">
    <summary>View as table</summary>
    <p>
      Refracted angle for a ray going from index {DEFAULT_N1} into index {DEFAULT_N2} as the
      incident angle grows.{
        defaultCritical === null
          ? ' Entering a denser medium, the ray always gets through, only bending closer to the normal.'
          : ` Past the critical angle of ${angleText(defaultCritical)} the ray is totally internally reflected.`
      }
    </p>
    <table>
      <thead>
        <tr>
          <th scope="col">Incident angle (°)</th>
          <th scope="col">Refracted angle (°)</th>
        </tr>
      </thead>
      <tbody>
        {
          rows.map((row) => (
            <tr>
              <td>{row.incident}</td>
              <td>{row.refracted}</td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </details>
</snell-ray>

<script>
  import { createVizCanvas } from '../../lib/canvas';
  import { criticalAngleDeg, refractionAngleDeg } from '../../lib/physics/snell';
  import { formatQuantity } from '../../lib/format';
  import { getVizStore } from '../../lib/vizStore';
  import type { VizTheme } from '../../lib/theme';

  const SLUG = 'waves-optics/snell';
  const DEFAULT_N1 = 1;
  const DEFAULT_N2 = 1.5;
  const DEFAULT_INCIDENT = 40;

  // This island seeds the shared store; it precedes the controls in the MDX and
  // module scripts run in document order, so it seeds before they connect.
  const store = getVizStore(SLUG, {
    n1: DEFAULT_N1,
    n2: DEFAULT_N2,
    incident: DEFAULT_INCIDENT,
  });

  const num = (values: Record<string, number>, key: string, fallback: number) =>
    values[key] ?? fallback;
  const angleText = (deg: number) => formatQuantity(deg, '°', { sigFigs: 3 });
  const DEG = Math.PI / 180;

  // Map a refractive index (1 .. 2.5) to a tint opacity so the denser medium
  // reads as visibly "thicker" glass. Colour still is never the only cue: the
  // rays, the normal, and the readouts all carry the information too.
  const tintAlpha = (n: number) => 0.06 + 0.16 * Math.min(Math.max((n - 1) / 1.5, 0), 1);

  function ray(
    ctx: CanvasRenderingContext2D,
    x0: number,
    y0: number,
    angleFromNormalDeg: number,
    goingDown: boolean,
    toRight: boolean,
    length: number,
    color: string,
    withHead: boolean,
    incoming = false,
  ): void {
    const a = angleFromNormalDeg * DEG;
    const dy = (goingDown ? 1 : -1) * Math.cos(a);
    const dx = (toRight ? 1 : -1) * Math.sin(a);
    const x1 = x0 + dx * length;
    const y1 = y0 + dy * length;
    ctx.strokeStyle = color;
    ctx.fillStyle = color;
    ctx.lineWidth = 3;
    ctx.beginPath();
    ctx.moveTo(x0, y0);
    ctx.lineTo(x1, y1);
    ctx.stroke();
    if (!withHead) return;
    // Outgoing rays point away from the origin (head at the far end); an incoming
    // (incident) ray points toward the interface (head at the origin).
    const headX = incoming ? x0 : x1;
    const headY = incoming ? y0 : y1;
    const ang = incoming ? Math.atan2(-dy, -dx) : Math.atan2(dy, dx);
    const head = 10;
    ctx.beginPath();
    ctx.moveTo(headX, headY);
    ctx.lineTo(headX - Math.cos(ang - 0.4) * head, headY - Math.sin(ang - 0.4) * head);
    ctx.lineTo(headX - Math.cos(ang + 0.4) * head, headY - Math.sin(ang + 0.4) * head);
    ctx.closePath();
    ctx.fill();
  }

  function draw(
    ctx: CanvasRenderingContext2D,
    size: { w: number; h: number },
    theme: VizTheme,
    values: Record<string, number>,
  ): void {
    const n1 = num(values, 'n1', DEFAULT_N1);
    const n2 = num(values, 'n2', DEFAULT_N2);
    const incident = num(values, 'incident', DEFAULT_INCIDENT);

    ctx.fillStyle = theme.bg;
    ctx.fillRect(0, 0, size.w, size.h);

    const cx = size.w * 0.5;
    const iy = size.h * 0.5; // interface height
    const len = Math.min(size.w, size.h) * 0.42;

    // Two tinted media. The incidence side (top) uses n1, transmission (bottom) n2.
    ctx.save();
    ctx.globalAlpha = tintAlpha(n1);
    ctx.fillStyle = theme.curveSecondary;
    ctx.fillRect(0, 0, size.w, iy);
    ctx.globalAlpha = tintAlpha(n2);
    ctx.fillStyle = theme.curve;
    ctx.fillRect(0, iy, size.w, size.h - iy);
    ctx.restore();

    // Interface line.
    ctx.strokeStyle = theme.axis;
    ctx.lineWidth = 2;
    ctx.beginPath();
    ctx.moveTo(0, iy);
    ctx.lineTo(size.w, iy);
    ctx.stroke();

    // Normal (dashed).
    ctx.save();
    ctx.strokeStyle = theme.axis;
    ctx.lineWidth = 1.5;
    ctx.setLineDash([6, 6]);
    ctx.beginPath();
    ctx.moveTo(cx, iy - len);
    ctx.lineTo(cx, iy + len);
    ctx.stroke();
    ctx.restore();

    // Incident ray comes down from the upper-left toward the origin (arrow points in).
    ray(ctx, cx, iy, incident, false, false, len, theme.active, true, true);

    const refracted = refractionAngleDeg(n1, n2, incident);

    if (refracted === null) {
      // Total internal reflection: no transmitted ray, mirror the incident ray
      // back into the first medium (equal angle, other side of the normal).
      ray(ctx, cx, iy, incident, false, true, len, theme.limit, true);
      ctx.fillStyle = theme.limit;
      ctx.font = 'bold 14px system-ui, sans-serif';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'bottom';
      ctx.fillText('total internal reflection', cx, iy - len - 6);
    } else {
      // Transmitted ray continues into the lower-right medium.
      ray(ctx, cx, iy, refracted, true, true, len, theme.curve, true);
    }

    // Angle readouts near the origin.
    ctx.fillStyle = theme.label;
    ctx.font = '13px system-ui, sans-serif';
    ctx.textAlign = 'right';
    ctx.textBaseline = 'bottom';
    ctx.fillText(`θ₁ = ${angleText(incident)}`, cx - 10, iy - 8);
    if (refracted !== null) {
      ctx.textAlign = 'left';
      ctx.textBaseline = 'top';
      ctx.fillText(`θ₂ = ${angleText(refracted)}`, cx + 10, iy + 8);
    }

    // Medium labels.
    ctx.fillStyle = theme.label;
    ctx.font = '12px system-ui, sans-serif';
    ctx.textAlign = 'left';
    ctx.textBaseline = 'top';
    ctx.fillText(`n₁ = ${formatQuantity(n1, '', { sigFigs: 3 })}`, 8, 8);
    ctx.textBaseline = 'bottom';
    ctx.fillText(`n₂ = ${formatQuantity(n2, '', { sigFigs: 3 })}`, 8, size.h - 8);
  }

  class SnellRayElement extends HTMLElement {
    #bound = false;

    connectedCallback() {
      if (this.#bound) return;
      this.#bound = true;

      const canvas = this.querySelector('canvas');
      if (!canvas) return;

      const incidentVal = this.querySelector('.incident-val');
      const refractedVal = this.querySelector('.refracted-val');
      const live = this.querySelector('.visually-hidden');

      const handle = createVizCanvas(
        canvas,
        (ctx, size, theme) => draw(ctx, size, theme, store.values.get()),
        { animate: false },
      );

      const refractedReadout = (values: Record<string, number>) => {
        const refracted = refractionAngleDeg(
          num(values, 'n1', DEFAULT_N1),
          num(values, 'n2', DEFAULT_N2),
          num(values, 'incident', DEFAULT_INCIDENT),
        );
        return refracted === null ? 'total internal reflection' : angleText(refracted);
      };

      const renderStat = (values: Record<string, number>) => {
        if (incidentVal)
          incidentVal.textContent = angleText(num(values, 'incident', DEFAULT_INCIDENT));
        if (refractedVal) refractedVal.textContent = refractedReadout(values);
      };

      store.values.subscribe((values) => {
        renderStat(values);
        handle.redraw();
      });

      store.onSettled((values) => {
        const text = `An incident angle of ${angleText(
          num(values, 'incident', DEFAULT_INCIDENT),
        )} gives a refracted angle of ${refractedReadout(values)}.`;
        if (live && live.textContent?.trim() !== text) live.textContent = text;
      });
    }
  }

  if (!customElements.get('snell-ray')) {
    customElements.define('snell-ray', SnellRayElement);
  }
</script>

<style>
  .field-figure {
    margin: 0;
  }

  .canvas-box {
    aspect-ratio: 3 / 2;
  }

  .ray-stat {
    margin-block: var(--space-2) 0;
    font-size: 1.05rem;
  }

  .ray-stat b {
    font-variant-numeric: tabular-nums;
    color: var(--viz-curve);
  }
</style>
