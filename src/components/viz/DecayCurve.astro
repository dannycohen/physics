---
import { formatQuantity } from '../../lib/format';
import { meanLifetime, remainingFraction } from '../../lib/physics/decay';

const SLUG = 'foundations/exponential-decay';
const DEFAULT_HALF_LIFE = 10;
const secs = (x: number) => formatQuantity(x, 's', { sigFigs: 3 });
const frac = (x: number) => formatQuantity(x, '', { sigFigs: 3 });

// Build-time table so the data exists without JavaScript. Includes t = one and
// two half-lives to show the 50% -> 25% step at the default half-life.
const SAMPLE_TIMES = [0, 5, 10, 15, 20, 30, 45, 60];
const rows = SAMPLE_TIMES.map((t) => ({
  t: formatQuantity(t, ''),
  frac: frac(remainingFraction(t, DEFAULT_HALF_LIFE)),
}));

const tau0 = meanLifetime(DEFAULT_HALF_LIFE);
---

<decay-curve data-slug={SLUG}>
  <figure class="decay-figure">
    <div class="canvas-box">
      <canvas
        role="img"
        aria-label="Graph of the fraction remaining against time. The curve starts at 1 and falls steeply at first, then flattens as it approaches zero without ever reaching it. A dashed marker line at the half-life meets the curve at one half remaining; a second dashed line at the mean lifetime meets it at about 37 percent."
      ></canvas>
    </div>
    <p class="decay-legend" aria-hidden="true">
      Half-life <b class="hl-val">{secs(DEFAULT_HALF_LIFE)}</b> (50% left) ·
      Mean lifetime <b class="tau-val">{secs(tau0)}</b> (37% left)
    </p>
    <span class="visually-hidden" aria-live="polite">
      Half-life {secs(DEFAULT_HALF_LIFE)}, so the mean lifetime is {secs(tau0)}. Half the sample
      remains after one half-life; about 37% remains after one mean lifetime.
    </span>
  </figure>
  <details class="view-table">
    <summary>View as table</summary>
    <p>
      Fraction remaining over time at a half-life of {secs(DEFAULT_HALF_LIFE)}. Each half-life halves
      what is left: 50% at {secs(DEFAULT_HALF_LIFE)}, 25% at {secs(2 * DEFAULT_HALF_LIFE)}.
    </p>
    <table>
      <thead>
        <tr>
          <th scope="col">t (s)</th>
          <th scope="col">Fraction remaining N/N₀</th>
        </tr>
      </thead>
      <tbody>
        {
          rows.map((row) => (
            <tr>
              <td>{row.t}</td>
              <td>{row.frac}</td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </details>
</decay-curve>

<script>
  import { createVizCanvas } from '../../lib/canvas';
  import { plotCurve, type Series } from '../../lib/plotCurve';
  import { meanLifetime, remainingFraction } from '../../lib/physics/decay';
  import { formatQuantity } from '../../lib/format';
  import { getVizStore } from '../../lib/vizStore';

  const SLUG = 'foundations/exponential-decay';
  const DEFAULT_HALF_LIFE = 10;
  const X_DOMAIN: [number, number] = [0, 60];
  const Y_DOMAIN: [number, number] = [0, 1.05];
  const STEPS = 240;

  // Seed the shared store before the controls connect.
  const store = getVizStore(SLUG, { halfLife: DEFAULT_HALF_LIFE });
  const clampHalf = (h: number | undefined) => Math.min(Math.max(h ?? DEFAULT_HALF_LIFE, 1), 30);
  const secs = (x: number) => formatQuantity(x, 's', { sigFigs: 3 });

  class DecayCurveElement extends HTMLElement {
    #bound = false;

    connectedCallback() {
      if (this.#bound) return;
      this.#bound = true;

      const canvas = this.querySelector('canvas');
      if (!canvas) return;

      const hlVal = this.querySelector('.hl-val');
      const tauVal = this.querySelector('.tau-val');
      const live = this.querySelector('.visually-hidden');

      const handle = createVizCanvas(
        canvas,
        (ctx, size, theme) => {
          const halfLife = clampHalf(store.values.get()['halfLife']);
          const tau = meanLifetime(halfLife);

          const decayPoints: Array<[number, number]> = [];
          for (let i = 0; i <= STEPS; i++) {
            const t = (i / STEPS) * X_DOMAIN[1];
            decayPoints.push([t, remainingFraction(t, halfLife)]);
          }

          // Vertical markers rise from the axis to the point where each meets the
          // curve: the half-life at 1/2 remaining, the mean lifetime at 1/e (~37%).
          // Distinct dash arrays keep them apart beyond colour (WCAG 1.4.1).
          const halfMarker: Array<[number, number]> = [
            [halfLife, 0],
            [halfLife, remainingFraction(halfLife, halfLife)],
          ];
          const tauMarker: Array<[number, number]> = [
            [tau, 0],
            [tau, remainingFraction(tau, halfLife)],
          ];

          const series: Series[] = [
            { points: decayPoints, color: theme.curve, label: 'N/N₀' },
            { points: halfMarker, color: theme.active, dash: [6, 4], label: '50%' },
            { points: tauMarker, color: theme.curveSecondary, dash: [2, 3], label: '37%' },
          ];

          plotCurve(ctx, size, theme, {
            series,
            xLabel: 'time t (s)',
            yLabel: 'N / N₀',
            xDomain: X_DOMAIN,
            yDomain: Y_DOMAIN,
          });
        },
        { animate: false },
      );

      const renderLegend = (values: Record<string, number>) => {
        const halfLife = clampHalf(values['halfLife']);
        if (hlVal) hlVal.textContent = secs(halfLife);
        if (tauVal) tauVal.textContent = secs(meanLifetime(halfLife));
      };

      store.values.subscribe((values) => {
        renderLegend(values);
        handle.redraw();
      });

      store.onSettled((values) => {
        const halfLife = clampHalf(values['halfLife']);
        const text = `Half-life ${secs(halfLife)}, so the mean lifetime is ${secs(meanLifetime(halfLife))}. Half the sample remains after one half-life; about 37% remains after one mean lifetime.`;
        if (live && live.textContent?.trim() !== text) live.textContent = text;
      });
    }
  }

  if (!customElements.get('decay-curve')) {
    customElements.define('decay-curve', DecayCurveElement);
  }
</script>

<style>
  .decay-figure {
    margin: 0;
  }

  .canvas-box {
    aspect-ratio: 16 / 10;
  }

  .decay-legend {
    margin-block: var(--space-2) 0;
    font-size: 1.05rem;
    color: var(--color-text-muted);
  }

  .decay-legend b {
    font-variant-numeric: tabular-nums;
    color: var(--color-text);
  }
</style>
