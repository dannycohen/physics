---
interface Props {
  slug: string;
  presets: Array<{
    label: string;
    icon?: string;
    caption?: string;
    values: Record<string, number>;
  }>;
}

const { slug, presets } = Astro.props;
---

<preset-buttons data-slug={slug}>
  <div class="preset-group" role="group" aria-label="Presets">
    {
      presets.map((preset) => (
        <button
          type="button"
          class="chip"
          data-values={JSON.stringify(preset.values)}
          data-caption={preset.caption}
        >
          {preset.icon && <span aria-hidden="true">{preset.icon} </span>}
          {preset.label}
        </button>
      ))
    }
  </div>
  <p class="preset-caption" aria-live="polite"></p>
</preset-buttons>

<script>
  import { getVizStore } from '../lib/vizStore';

  class PresetButtonsElement extends HTMLElement {
    #bound = false;

    connectedCallback() {
      if (this.#bound) return;
      this.#bound = true;

      const store = getVizStore(this.dataset.slug ?? '');
      const caption = this.querySelector('.preset-caption');
      // The values the visible caption describes; cleared once the store
      // diverges (slider drag, limit snap) so a stale caption never lingers.
      let active: Record<string, number> | null = null;

      for (const button of this.querySelectorAll<HTMLButtonElement>('button[data-values]')) {
        button.addEventListener('click', () => {
          const values = JSON.parse(button.dataset.values ?? '{}') as Record<string, number>;
          for (const [key, value] of Object.entries(values)) {
            store.set(key, value);
          }
          active = values;
          if (caption) caption.textContent = button.dataset.caption ?? '';
        });
      }

      store.values.subscribe((values) => {
        if (!active || !caption) return;
        if (Object.entries(active).some(([key, value]) => values[key] !== value)) {
          active = null;
          caption.textContent = '';
        }
      });
    }
  }

  if (!customElements.get('preset-buttons')) {
    customElements.define('preset-buttons', PresetButtonsElement);
  }
</script>

<style>
  .preset-group {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .preset-caption {
    min-height: 3.2em; /* two lines: captions are kept short enough to fit */
    margin-block: var(--space-2) 0;
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }
</style>
