---
interface Props {
  slug: string;
  presets: Array<{ label: string; caption?: string; values: Record<string, number> }>;
}

const { slug, presets } = Astro.props;
---

<preset-buttons data-slug={slug}>
  <div class="preset-group" role="group" aria-label="Presets">
    {
      presets.map((preset) => (
        <button type="button" data-values={JSON.stringify(preset.values)} data-caption={preset.caption}>
          {preset.label}
        </button>
      ))
    }
  </div>
  <p class="preset-caption" aria-live="polite"></p>
</preset-buttons>

<script>
  import { getVizStore } from '../lib/vizStore';

  class PresetButtonsElement extends HTMLElement {
    #bound = false;

    connectedCallback() {
      if (this.#bound) return;
      this.#bound = true;

      const store = getVizStore(this.dataset.slug ?? '');
      const caption = this.querySelector('.preset-caption');

      for (const button of this.querySelectorAll<HTMLButtonElement>('button[data-values]')) {
        button.addEventListener('click', () => {
          const values = JSON.parse(button.dataset.values ?? '{}') as Record<string, number>;
          for (const [key, value] of Object.entries(values)) {
            store.set(key, value);
          }
          if (caption) caption.textContent = button.dataset.caption ?? '';
        });
      }
    }
  }

  if (!customElements.get('preset-buttons')) {
    customElements.define('preset-buttons', PresetButtonsElement);
  }
</script>

<style>
  .preset-group {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  button {
    min-width: 24px;
    min-height: 24px;
    padding: var(--space-1) var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-surface);
    color: var(--color-text);
    font: inherit;
    cursor: pointer;
  }

  button:hover {
    border-color: var(--color-focus);
  }

  .preset-caption {
    min-height: 1.6em; /* reserve the line so announcements don't shift layout */
    margin-block: var(--space-2) 0;
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }
</style>
