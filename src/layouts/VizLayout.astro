---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import { renderLatex, renderLatexInline } from '../lib/renderLatex';

interface Props {
  entry: CollectionEntry<'viz'>;
}

const { entry } = Astro.props;
const { title, claim, equationLatex, terms } = entry.data;

// Frozen page contract (validated across the comparison, distribution, and
// field-space archetypes): title + claim, then the MDX body (its viz island(s),
// a .viz-controls block, and prose), then an auto-generated "Show the math"
// panel from the frontmatter equation and terms. Islands emit their own
// "View as table" fallback. See AGENTS.md.
---

<BaseLayout title={title} description={claim}>
  <article class="viz-page">
    <h1>{title}</h1>
    <p class="claim">{claim}</p>

    <div class="viz-prose">
      <slot />
    </div>

    <details class="show-math">
      <summary>Show the math</summary>
      <div class="equation" set:html={renderLatex(equationLatex)} />
      {
        terms.length > 0 && (
          <table>
            <thead>
              <tr>
                <th scope="col">Symbol</th>
                <th scope="col">Role</th>
                <th scope="col">Effect on output</th>
              </tr>
            </thead>
            <tbody>
              {terms.map((t) => (
                <tr>
                  <td title={t.name}>
                    <Fragment set:html={renderLatexInline(t.symbol)} />
                    <span class="visually-hidden">{t.name}</span>
                  </td>
                  <td>{t.role}</td>
                  <td>{t.effect}</td>
                </tr>
              ))}
            </tbody>
          </table>
        )
      }
    </details>
  </article>
</BaseLayout>

<style>
  .viz-page {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding-block: var(--space-4);
  }

  .viz-page > h1,
  .viz-page > .claim {
    margin: 0;
  }

  .claim {
    font-size: 1.3rem;
    line-height: 1.4;
    color: var(--color-text);
    font-weight: 500;
  }

  .viz-prose {
    container-type: inline-size;
  }

  details {
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: var(--space-2) var(--space-3);
  }

  details summary {
    cursor: pointer;
    font-weight: 600;
  }

  .show-math .equation {
    overflow-x: auto;
    padding-block: var(--space-2);
  }

  .show-math table {
    width: 100%;
    border-collapse: collapse;
  }

  .show-math th,
  .show-math td {
    text-align: left;
    padding: var(--space-1) var(--space-2);
    border-bottom: 1px solid var(--color-border);
  }

  .show-math td[title] {
    cursor: help;
  }
</style>
