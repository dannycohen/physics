---
import BaseLayout from '../layouts/BaseLayout.astro';
import LandingSwitcher from '../components/LandingSwitcher.astro';
import { getCatalog } from '../lib/catalog';

const { live, byCategory } = await getCatalog();
const hero = live[0];
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Physics, one equation at a time"
  description="Interactive visualizations that explain the meaning and structure of the equations of physics."
>
  <h1>Grab a slider. Bend the universe.</h1>
  <p>
    Every page here is one famous equation of physics turned into a toy. Drag a slider,
    watch clocks slow down and curves shoot up, and find out why the equation has the
    shape it does. No prior physics needed, just curiosity.
  </p>
  {
    hero && (
      <p class="hero-link">
        <strong>Start here:</strong>{' '}
        <a href={`${base}viz/${hero.id}/`}>{hero.data.title}</a> — {hero.data.claim}
      </p>
    )
  }

  <LandingSwitcher current="" />

  {
    byCategory.map((group) => (
      <section>
        <h2>{group.label}</h2>
        <ul>
          {group.entries.map((e) =>
            e.data.status === 'live' ? (
              <li>
                <a href={`${base}viz/${e.id}/`}>{e.data.title}</a> — {e.data.claim}
              </li>
            ) : (
              <li>
                <span class="coming-soon">{e.data.title} (coming soon)</span>
              </li>
            ),
          )}
        </ul>
      </section>
    ))
  }
</BaseLayout>

<style>
  .coming-soon {
    color: var(--color-text-muted);
  }
  .hero-link {
    background: var(--color-surface);
    padding: var(--space-3);
    border-radius: var(--radius);
  }
</style>
